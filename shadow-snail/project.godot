; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="影噬"
run/main_scene="res://scenes/ui/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameFlow="*res://scripts/core/game_flow.gd"
SessionState="*res://scripts/core/session_state.gd"
CharacterCatalog="*res://scripts/core/character_catalog.gd"
NetworkManager="*res://scripts/network/network_manager.gd"
LobbySync="*res://scripts/network/lobby_sync.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[internationalization]

locale/fallback="zh_CN"
locale="zh_CN"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
